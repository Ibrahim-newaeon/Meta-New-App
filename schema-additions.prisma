// prisma/schema.prisma — APPEND to existing schema (adds auth models)
// Run: npx prisma migrate dev --name add-auth

// ─── Auth — NextAuth adapter models ──────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hash — null for OAuth users

  // RBAC
  role          Role      @default(CLIENT_VIEW)
  // For CLIENT_VIEW users — restricts access to their clients only
  allowedClientIds String[]  @default([])
  active        Boolean   @default(true)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]

  @@index([email])
  @@index([role])
}

enum Role {
  ADMIN        // Full access — all clients, all features, user management
  ACCOUNT_MGR  // All clients they manage, cannot manage users
  CLIENT_VIEW  // Read-only access to their specific client reports
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
